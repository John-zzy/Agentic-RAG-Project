# Model API keys
AI_RAG_MODELS__SIMPLE__API_KEY=your-dashscope-api-key
AI_RAG_MODELS__MODERATE__API_KEY=your-dashscope-api-key
AI_RAG_MODELS__COMPLEX__API_KEY=your-dashscope-api-key

# Default scene used for new sessions when no scene is explicitly selected
AI_RAG_APP__ACTIVE_SCENE=generic_assistant

# Optional host / port overrides
#AI_RAG_HOST=127.0.0.1
#AI_RAG_PORT=8000

# Vector store provider
AI_RAG_VECTOR_STORE__PROVIDER=chroma

# Chroma
#AI_RAG_VECTOR_STORE__CHROMA__PERSIST_DIRECTORY=data/.chroma

# Elasticsearch
#AI_RAG_VECTOR_STORE__ELASTICSEARCH__URL=http://127.0.0.1:9200
#AI_RAG_VECTOR_STORE__ELASTICSEARCH__USERNAME=
#AI_RAG_VECTOR_STORE__ELASTICSEARCH__PASSWORD=
#AI_RAG_VECTOR_STORE__ELASTICSEARCH__API_KEY=
#AI_RAG_VECTOR_STORE__ELASTICSEARCH__VERIFY_CERTS=true
#AI_RAG_VECTOR_STORE__ELASTICSEARCH__REQUEST_TIMEOUT_SECONDS=30
#AI_RAG_VECTOR_STORE__ELASTICSEARCH__INDEX_PREFIX=ai-rag

# Optional scene knowledge source mapping
#AI_RAG_VECTOR_STORE__KNOWLEDGE_SOURCES={"products":{"collection_name":"products","index_name":"ai-rag-products"},"reviews":{"collection_name":"reviews","index_name":"ai-rag-reviews"},"orders":{"collection_name":"orders","index_name":"ai-rag-orders"}}
